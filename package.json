{
  "name": "jyotish-pro",
  "version": "0.1.0",
  "private": true,
  "description": "Astrologer Hemraj Laddha — Vedic Astrology Suite",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w server && npm run build -w client",
    "build:client": "npm run build -w client",
    "build:server": "npm run build -w server",
    "postinstall": "node server/scripts/download-ephe.js",
    "start": "JYOTISH_CLIENT_DIST=$PWD/client/dist NODE_ENV=production node server/dist/index.js"
  },

  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.1",
    "mongodb": "^7.2.0",
    "puppeteer": "^24.40.0",
    "swisseph": "^0.5.17"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "wait-on": "^8.0.1"
  }
}
